# MotherDuck service token (https://app.motherduck.com -> Settings -> Access Tokens)
MOTHERDUCK_TOKEN=your_motherduck_token_here

# Destination MotherDuck database name
MOTHERDUCK_DATABASE=peloton_data

# Peloton OAuth client ID. Defaults to the public Peloton web client, so you
# normally do not need to change this.
PELOTON_CLIENT_ID=WVoJxVDdPoFx4RNewvvg6ch2mZ7bwnsM

# Peloton login credentials. Only needed LOCALLY for the first-time login
# (python peloton_login.py) to mint peloton_tokens.json. NOT needed in CI,
# which authenticates with the refresh token only. Leave blank otherwise.
PELOTON_USERNAME=your_peloton_email_here
PELOTON_PASSWORD=your_peloton_password_here

# Optional: override the local tokens file path (defaults to peloton_tokens.json)
# PELOTON_TOKENS_FILE=peloton_tokens.json
